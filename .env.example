# hermes-web-ui — .env example
#
# Copy this file to `.env` and adjust per deployment.
# `.env` itself is gitignored — never commit secrets.
#
# Every variable below is optional unless marked REQUIRED.
# Variables are grouped by responsibility; comment-out blocks you do not use.

# ─────────────────────────────────────────────────────────────
# Core WebUI server
# ─────────────────────────────────────────────────────────────
PORT=8648
BIND_HOST=0.0.0.0                 # set to :: for IPv6
# UPLOAD_DIR=                     # default: ~/.hermes-web-ui/upload
# CORS_ORIGINS=                   # comma-separated; default: same-origin only (no header)
SESSION_STORE=local               # local (sqlite) | remote (proxy to Hermes CLI)
# AUTH_DISABLED=false             # 1/true/yes/on to disable auth entirely (dev only)

# ─────────────────────────────────────────────────────────────
# Auth mode — choose ONE of: token / trusted-feishu / feishu-oauth-dev
# ─────────────────────────────────────────────────────────────
#   token            : default; local-generated key in ~/.hermes-web-ui/.token
#   trusted-feishu   : verify HMAC headers injected by a reverse proxy (Nginx)
#   feishu-oauth-dev : WebUI handles Feishu OAuth callback itself (no proxy)
HERMES_AUTH_MODE=token

# Web plane — chat (end-user only) / ops (admin only) / both
HERMES_WEB_PLANE=both
# HERMES_CHAT_PLANE_ALLOW_SETTINGS=false
# HERMES_CHAT_PLANE_TEMP_OPEN_ADMIN=false

# ─────────────────────────────────────────────────────────────
# Trusted header auth (only when HERMES_AUTH_MODE=trusted-feishu)
# ─────────────────────────────────────────────────────────────
# HERMES_TRUSTED_HEADER_OPENID=X-Feishu-OpenID
# HERMES_TRUSTED_HEADER_TIMESTAMP=X-Hermes-Auth-Timestamp
# HERMES_TRUSTED_HEADER_SIG=X-Hermes-Auth-Signature
# HERMES_TRUSTED_HEADER_SECRET=            # REQUIRED — HMAC shared secret with proxy
# HERMES_TRUSTED_HEADER_MAX_AGE_SECONDS=300

# ─────────────────────────────────────────────────────────────
# Feishu OAuth (only when HERMES_AUTH_MODE=feishu-oauth-dev)
# ─────────────────────────────────────────────────────────────
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_REDIRECT_URI=                     # e.g. http://10.250.1.66:8648/api/auth/feishu/callback
# FEISHU_AUTHORIZE_URL=https://open.feishu.cn/open-apis/authen/v1/index
# FEISHU_API_BASE_URL=https://open.feishu.cn
# FEISHU_SESSION_SECRET=                   # REQUIRED — signs OAuth session cookies
# FEISHU_SESSION_MAX_AGE_SECONDS=604800    # 7 days
# FEISHU_CALLBACK_REDIRECT=/#/

# ─────────────────────────────────────────────────────────────
# Multitenancy
# ─────────────────────────────────────────────────────────────
# HERMES_MULTITENANCY_DB=~/.hermes/multitenancy.db   # path to the routing DB

# ─────────────────────────────────────────────────────────────
# Run Broker execution path (opt-in)
# ─────────────────────────────────────────────────────────────
# When enabled, WebUI chat runs are submitted to the router-owned
# multitenancy Run Broker instead of directly calling a profile apiserver.
# Keep disabled until the matching multitenancy sidecar and sandbox canary
# have passed.
# HERMES_WEBUI_RUN_BROKER=false
# HERMES_WEBUI_JOBS_BROKER=              # optional override; defaults to HERMES_WEBUI_RUN_BROKER
# HERMES_RUN_BROKER_URL=http://127.0.0.1:8766
# HERMES_RUN_BROKER_KEY=                  # optional Bearer shared secret

# ─────────────────────────────────────────────────────────────
# Gateway lifecycle — managed by GatewayManager in WebUI process
# ─────────────────────────────────────────────────────────────
#   all    : spawn one gateway per profile on startup (recommended for multi-tenant)
#   active : spawn only the currently active profile's gateway
#   none   : do not auto-spawn (e.g. when systemd manages gateways)
GATEWAY_AUTOSTART=all

# ─────────────────────────────────────────────────────────────
# Single-upstream short-circuit (NOT recommended for multi-tenant)
# ─────────────────────────────────────────────────────────────
# Setting these makes the WebUI proxy ALL /v1/* directly to one upstream
# gateway, bypassing GatewayManager + per-profile spawning. Side effect:
# every WebUI user shares ONE profile's runtime (sessions, cron, approvals).
# Acceptable for single-tenant dev / first-day bring-up; do NOT keep this
# in production multi-tenant deployments.
#
# HERMES_PROFILE=multitenancy_router
# UPSTREAM=http://127.0.0.1:8652
# API_SERVER_KEY=                          # the upstream's API key (from profile .env)
